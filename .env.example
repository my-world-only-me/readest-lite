# ───────────────────────────────────────────────────────────────────────────
# Readest Lite — 环境变量样例
# 复制为 .env 并按需修改
# ───────────────────────────────────────────────────────────────────────────

# ── 管理员账号（必填）──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@readest.local
ADMIN_PASSWORD=ChangeMeToSomethingStrong!

# ── JWT 密钥（必填，建议 32+ 字符随机串）────────────────────────────────────
# 生成命令：openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── JWT 有效期 ────────────────────────────────────────────────────────────
JWT_EXP_SECONDS=604800        # 7 天
REFRESH_EXP_SECONDS=2592000   # 30 天

# ── 数据库 ────────────────────────────────────────────────────────────────
DATABASE_URL=file:/data/db/readest.db

# ── 存储路径 ──────────────────────────────────────────────────────────────
BOOKS_DIR=/data/books
INBOX_DIR=/data/inbox

# ── 对外访问 URL（用于生成签名上传/下载 URL 的 host）─────────────────────────
PUBLIC_BASE_URL=http://localhost:8225

# ── 前端 supabase-js 客户端指向本地 ─────────────────────────────────────────
# 必须与 PUBLIC_BASE_URL 一致，否则前端登录请求会打到错地址
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8225
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon
NEXT_PUBLIC_APP_PLATFORM=web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8225/api

# ── 运行时配置（runtime-config.js 注入）────────────────────────────────────
OBJECT_STORAGE_TYPE=local
STORAGE_FIXED_QUOTA=0          # 0 = 无限
TRANSLATION_FIXED_QUOTA=0      # 0 = 无限

# ── DeepL（可选，不配置则翻译功能不可用）──────────────────────────────────
DEEPL_FREE_API_KEYS=
DEEPL_PRO_API_KEYS=

# ── AI Gateway（可选，不配置则 AI 聊天不可用）─────────────────────────────
AI_GATEWAY_API_KEY=

# ── 容器端口 ──────────────────────────────────────────────────────────────
PORT=8225
HOSTNAME=0.0.0.0
